# --- RocketRide (auto-managed by extension; do not edit directly) ---
ROCKETRIDE_URI=https://cloud.rocketride.ai
ROCKETRIDE_APIKEY=your-rocketride-api-key

# --- GMI Cloud (hosts Gemini 3 Flash for the commentary LLM) ---
# Sign up at https://console.gmicloud.ai and grab an API key.
GMI_BASE_URL=https://api.gmi-serving.com/v1
GMI_MODEL=google/gemma-4-31b-it
ROCKETRIDE_GMI_APIKEY=your-gmi-cloud-api-key

# --- Google Gemini (vision + commentary; Live is no longer the TTS path) ---
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-ai-studio-key
GEMINI_VISION_MODEL=gemini-3.1-flash-lite
GEMINI_COMMENTARY_MODEL=gemini-3.1-flash-lite
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# --- MiniMax TTS via GMI Cloud (the actual voice path) ---
# https://docs.gmicloud.ai/model-quickstarts/audio/overview
MINIMAX_BASE_URL=https://console.gmicloud.ai
MINIMAX_TTS_MODEL=minimax-tts-speech-2.6-hd
MINIMAX_VOICE_ID=English_expressive_narrator
MINIMAX_POLL_TIMEOUT_S=30
MINIMAX_POLL_INTERVAL_S=1.5

# --- Backend server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Sampling knobs (tune for demo latency) ---
FRAME_SAMPLE_FPS=1.5
COMMENTARY_MAX_TOKENS=80
